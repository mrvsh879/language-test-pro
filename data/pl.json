anation":"Poprawna odpowiedź: Odebrać przesyłkę jutro."},{"id":"pl-a2-r-03","level":"A2","skill":"reading","prompt":"Kiedy należy dostarczyć dokumenty?","options":["W piątek wieczorem","Najpóźniej w czwartek","W sobotę","W poniedziałek"],"answer":1,"passage":"W piątek biuro pracuje tylko do 13:00. Dokumenty prosimy dostarczyć najpóźniej w czwartek.","explanation":"Poprawna odpowiedź: Najpóźniej w czwartek."},{"id":"pl-a2-r-04","level":"A2","skill":"reading","prompt":"Gdzie odbędą się pierwsze spotkania?","options":["W sali 21","Online","W bibliotece","W biurze"],"answer":1,"passage":"Pierwsze dwa spotkania kursu odbędą się online. Kolejne zajęcia będą w sali 21.","explanation":"Poprawna odpowiedź: Online."},{"id":"pl-a2-r-05","level":"A2","skill":"reading","prompt":"Ile może kosztować naprawa z baterią?","options":["500 zł","580 zł","620 zł","720 zł"],"answer":2,"passage":"Naprawa kosztuje 500 zł. Wymiana baterii zwiększy cenę o 120 zł.","explanation":"Poprawna odpowiedź: 620 zł."},{"id":"pl-a2-r-06","level":"A2","skill":"reading","prompt":"Do której jest śniadanie w weekend?","options":["Do 9:30","Do 10:00","Do 10:30","Do 11:00"],"answer":2,"passage":"Hotel oferuje śniadanie od 7:00 do 10:00, a w weekend do 10:30.","explanation":"Poprawna odpowiedź: Do 10:30."},{"id":"pl-b1-g-01","level":"B1","skill":"grammar","prompt":"Gdybym miał więcej czasu, ___ się polskiego.","options":["uczę","uczyłbym","nauczę","uczyłem"],"answer":1,"explanation":"Poprawna odpowiedź: uczyłbym."},{"id":"pl-b1-g-02","level":"B1","skill":"grammar","prompt":"To jest projekt, nad ___ pracujemy od miesiąca.","options":["który","którym","którego","któremu"],"answer":1,"explanation":"Poprawna odpowiedź: którym."},{"id":"pl-b1-g-03","level":"B1","skill":"grammar","prompt":"Kiedy przyszedłem, oni już ___.","options":["wyszli","wychodzą","wyjdą","wyszliby"],"answer":0,"explanation":"Poprawna odpowiedź: wyszli."},{"id":"pl-b1-g-04","level":"B1","skill":"grammar","prompt":"Powiedział, że ___ dokument następnego dnia.","options":["wyśle","wysłał","wysyła","wysyłałby"],"answer":0,"explanation":"Poprawna odpowiedź: wyśle."},{"id":"pl-b1-g-05","level":"B1","skill":"grammar","prompt":"Nie mogę przyjść, ponieważ ___ chory.","options":["jestem","będę","byłem być","mam"],"answer":0,"explanation":"Poprawna odpowiedź: jestem."},{"id":"pl-b1-g-06","level":"B1","skill":"grammar","prompt":"Im więcej ćwiczysz, tym ___ mówisz.","options":["lepiej","dobry","najlepszy","dobre"],"answer":0,"explanation":"Poprawna odpowiedź: lepiej."},{"id":"pl-b1-g-07","level":"B1","skill":"grammar","prompt":"Proszę, żeby pani ___ ten formularz.","options":["podpisze","podpisała","podpisywać","podpisuje"],"answer":1,"explanation":"Poprawna odpowiedź: podpisała."},{"id":"pl-b1-v-01","level":"B1","skill":"vocabulary","prompt":"Osoba „rzetelna” ___.","options":["unika odpowiedzialności","wykonuje obowiązki dokładnie","często się spóźnia","nie przyjmuje uwag"],"answer":1,"explanation":"Poprawna odpowiedź: wykonuje obowiązki dokładnie."},{"id":"pl-b1-v-02","level":"B1","skill":"vocabulary","prompt":"„Rozważyć propozycję” znaczy ___.","options":["odrzucić ją bez analizy","dokładnie ją przemyśleć","zapomnieć o niej","natychmiast podpisać"],"answer":1,"explanation":"Poprawna odpowiedź: dokładnie ją przemyśleć."},{"id":"pl-b1-v-03","level":"B1","skill":"vocabulary","prompt":"Jeśli termin jest „elastyczny”, można go ___.","options":["w pewnym zakresie zmienić","całkowicie usunąć","ukryć","zapłacić"],"answer":0,"explanation":"Poprawna odpowiedź: w pewnym zakresie zmienić."},{"id":"pl-b1-v-04","level":"B1","skill":"vocabulary","prompt":"„Osiągnąć cel” znaczy ___.","options":["zrezygnować","zrealizować zamierzony wynik","zmienić temat","stracić czas"],"answer":1,"explanation":"Poprawna odpowiedź: zrealizować zamierzony wynik."},{"id":"pl-b1-v-05","level":"B1","skill":"vocabulary","prompt":"„Uzasadnić decyzję” to ___.","options":["podać jej powody","odwołać ją","przekazać ją komuś","zachować w tajemnicy"],"answe